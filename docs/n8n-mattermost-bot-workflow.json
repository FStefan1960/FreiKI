        "headerParameters": {
          "parameters": [
            { "name": "X-API-Key", "value": "BITTE_HIER_BOT_API_KEY_EINTRAGEN" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"message\": {{ JSON.stringify($json.body.text) }},\n  \"username\": {{ JSON.stringify($json.body.user_name) }}\n}",
        "options": {}
      },
      "name": "FreiKI Bot-Chat aufrufen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [100, 420],
      "id": "1a2b3c4d-0003-4000-8000-000000000003"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('Mattermost Slash-Command Webhook').item.json.body.response_url }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"response_type\": \"in_channel\",\n  \"text\": {{ JSON.stringify($json.answer) }}\n}",
        "options": {}
      },
      "name": "Antwort an Mattermost-Channel",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [380, 420],
      "id": "1a2b3c4d-0004-4000-8000-000000000004"
    }
  ],
  "connections": {
