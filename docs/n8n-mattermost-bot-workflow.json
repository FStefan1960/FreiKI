    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"response_type\": \"ephemeral\",\n  \"text\": \"FreiKI denkt nach …\"\n}",
        "options": {}
      },
      "name": "Sofortige Bestätigung",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [100, 140],
      "id": "1a2b3c4d-0002-4000-8000-000000000002"
    },
    {
      "parameters": {
        "method": "POST",
