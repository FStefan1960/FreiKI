      {
        "id": "a2ed9215-af19-4345-bad3-fe04f95ca95e",
        "name": "Tag-ID ermitteln",
        "type": "n8n-nodes-base.code",
        "position": [
          560,
          592
        ],
        "parameters": {
          "jsCode": "const httpResp = $input.item.json;\nconst tagItem = $('Tags aufteilen').item.json;\n\nlet resolvedTagId = null;\nif (httpResp.id) {\n  resolvedTagId = httpResp.id;\n} else {\n  resolvedTagId = (tagItem.tagMap || {})[tagItem.currentTagName] || null;\n}\nreturn [{ json: { ...tagItem, resolvedTagId } }];"
        },
        "typeVersion": 2
      },
      {
        "id": "d64af88a-1ad2-453f-9e04-4c11b88dcead",
        "name": "Patch vorbereiten",
        "type": "n8n-nodes-base.code",
        "position": [
          160,
          224
        ],
        "parameters": {
          "jsCode": "const items = $input.all();\n\n// Pfad 1: keine neuen Tags nötig\nif (items[0]?.json?.skipTagCreation) {\n  const d = items[0].json;\n  const patch = { docId: d.docId, title: d.title, finalTagIds: d.existingTagIds };\n  if (d.correspondentId) patch.correspondentId = d.correspondentId;\n  if (d.documentTypeId) patch.documentTypeId = d.documentTypeId;\n  if (d.created) patch.created = d.created;\n  return [{ json: patch }];\n}\n\n// Pfad 2: nach Tag-Erstellung (Items aus inner-loop done)\nconst base = items[0].json;\nconst collectedIds = [...base.existingTagIds];\nfor (const item of items) {\n  const id = item.json.resolvedTagId;\n  if (id && !collectedIds.includes(id)) collectedIds.push(id);\n}\nconst patch = { docId: base.docId, title: base.title, finalTagIds: collectedIds };\nif (base.correspondentId) patch.correspondentId = base.correspondentId;\nif (base.documentTypeId) patch.documentTypeId = base.documentTypeId;\nif (base.created) patch.created = base.created;\nreturn [{ json: patch }];"
        },
        "typeVersion": 2
      },
      {
        "id": "92448512-d671-4560-a239-f4fc9cd8aad7",
        "name": "PATCH-Body aufbauen",
        "type": "n8n-nodes-base.code",
        "position": [
          368,
          224
        ],
        "parameters": {
          "jsCode": "const d = $input.item.json;\nconst body = { title: d.title, tags: d.finalTagIds };\nif (d.correspondentId != null) body.correspondent = d.correspondentId;\nif (d.documentTypeId != null) body.document_type = d.documentTypeId;\nif (d.created) body.created = d.created;\nreturn [{ json: { ...d, patchBody: JSON.stringify(body) } }];"
        },
        "typeVersion": 2
      },
