        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  (SELECT count(*) FROM kb_beb_stellungnahmen WHERE embedding IS NOT NULL) AS stellungnahmen,\n  (SELECT count(*) FROM kb_beb_tagungen       WHERE embedding IS NOT NULL) AS tagungen,\n  (SELECT count(*) FROM kb_beb_grundlagen     WHERE embedding IS NOT NULL) AS grundlagen",
          "options": {}
        },
