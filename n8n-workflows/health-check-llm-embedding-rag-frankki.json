            "id": "RtGbSsO0K5UqGVHs",
            "name": "Postgres account"
          }
        },
        "continueOnFail": true
      },
      {
        "parameters": {
          "jsCode": "const items = $input.all();\nconst llm    = items[0];\nconst embed  = items[1];\nconst rag    = items[2];\nconst login  = items[3];\nconst archiv = items[4];\n\nconst appName = 'FrankKI';\nconst errors = [];\n\nif (!llm || llm.error || !llm.json?.choices?.[0]) {\n  errors.push('LLM: ' + (llm?.error?.message || JSON.stringify(llm?.json) || 'Keine Antwort'));\n}\nif (!embed || embed.error || !embed.json?.data?.[0]?.embedding?.length) {\n  errors.push('Embedding: ' + (embed?.error?.message || JSON.stringify(embed?.json) || 'Kein Vektor'));\n}\nif (!rag || rag.error) {\n  errors.push('RAG-DB: ' + (rag?.error?.message || 'Keine Verbindung'));\n} else {\n  const r = rag.json;\n  const missing = [];\n  if (!r?.stellungnahmen || parseInt(r.stellungnahmen) === 0) missing.push('kb_beb_stellungnahmen');\n  if (!r?.tagungen       || parseInt(r.tagungen)       === 0) missing.push('kb_beb_tagungen');\n  if (!r?.grundlagen     || parseInt(r.grundlagen)     === 0) missing.push('kb_beb_grundlagen');\n  if (missing.length > 0) errors.push('RAG leer/keine Embeddings: ' + missing.join(', '));\n}\nif (!login || login.error || !login.json?.token) {\n  errors.push('Login: ' + (login?.error?.message || JSON.stringify(login?.json) || 'Kein Token'));\n}\nif (!archiv || archiv.error || archiv.json?.count === undefined || archiv.json?.count === 0) {\n  errors.push('Archiv: ' + (archiv?.error?.message || JSON.stringify(archiv?.json) || 'Keine Ergebnisse'));\n}\n\nconst ok = errors.length === 0;\nreturn [{\n  json: {\n    ok, appName, errors,\n    subject: ok\n      ? '[OK] ' + appName + ' Health-Check: Alles in Ordnung'\n      : '[FEHLER] ' + appName + ' Health-Check: ' + errors.length + ' Problem(e)',\n    body: ok\n      ? appName + ': LLM, Embedding, RAG, Login und Archiv laufen einwandfrei.'\n      : appName + ' meldet Probleme:\\\\n\\\\n' + errors.join('\\\\n') + '\\\\n\\\\nBitte prüfen.'\n  }\n}];"
        },
