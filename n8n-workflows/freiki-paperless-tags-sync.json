    "id": "19YTRAUMpoH3mywV",
    "name": "FreiKI Paperless Tags synchronisieren",
    "active": true,
    "nodes": [
      {
        "id": "schedule-trigger-tagsync",
        "name": "Täglich",
        "type": "n8n-nodes-base.scheduleTrigger",
        "position": [
          -500,
