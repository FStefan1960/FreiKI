        "typeVersion": 1.2
      },
      {
        "id": "http-get-areas",
        "name": "KB-Bereiche holen",
        "type": "n8n-nodes-base.httpRequest",
        "position": [
          -280,
          80
        ],
        "parameters": {
          "url": "http://freiki-ui:3000/api/kb-areas",
          "options": {},
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "X-API-Key",
