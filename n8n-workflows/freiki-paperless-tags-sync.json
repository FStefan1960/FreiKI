              }
            ]
          }
        },
        "typeVersion": 4.2
      },
      {
        "id": "http-get-tags",
        "name": "Paperless Tags holen",
        "type": "n8n-nodes-base.httpRequest",
        "position": [
          -60,
          80
        ],
        "parameters": {
          "url": "http://paperless:8000/api/tags/?page_size=100",
          "options": {},
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "Authorization",
                "value": "=Token {{$env.PAPERLESS_TOKEN}}"
              }
            ]
          }
        },
        "typeVersion": 4.2
      },
      {
        "id": "code-find-missing",
        "name": "Fehlende Tags ermitteln",
        "type": "n8n-nodes-base.code",
        "position": [
          160,
          80
        ],
        "parameters": {
          "jsCode": "const areas = $('KB-Bereiche holen').first().json.areas || [];\nconst existingTags = $input.first().json.results || [];\nconst existingNames = existingTags.map(t => t.name.toLowerCase());\n\nconst missing = areas.filter(a => !existingNames.includes(a));\nreturn missing.map(name => ({ json: { name } }));"
        },
        "typeVersion": 2
      },
      {
        "id": "http-create-tag",
        "name": "Tag in Paperless anlegen",
        "type": "n8n-nodes-base.httpRequest",
        "position": [
          380,
          80
        ],
        "parameters": {
          "url": "http://paperless:8000/api/tags/",
          "method": "POST",
          "options": {},
          "jsonBody": "={{ { name: $json.name } }}",
          "sendBody": true,
          "sendHeaders": true,
          "specifyBody": "json",
          "headerParameters": {
            "parameters": [
              {
                "name": "Authorization",
                "value": "=Token {{$env.PAPERLESS_TOKEN}}"
              },
              {
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        },
        "typeVersion": 4.2
      }
    ],
