# ── Lokal erzeugt – diese Datei NICHT ins Git/Repo committen, nur per scp auf den Server kopieren ──

# --- PostgreSQL ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- n8n ---
N8N_HOST=
WEBHOOK_URL=
N8N_ENCRYPTION_KEY=
N8N_WEBHOOK_URL=
# API-Key (generiert in n8n UI unter Settings → API)
N8N_API_KEY=
# Telemetrie deaktivieren
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false

# --- LLM-Backend: DeepInfra (OpenAI-kompatibel) ---
# Modell: Qwen/Qwen3-32B (40k Kontext) – bereits fest in server.js eingetragen
VLLM_URL=
VLLM_API_KEY=
VLLM_MODEL=
# Embedding: BAAI/bge-m3 – bereits fest in server.js eingetragen (EMBED_MODEL)
VLLM_EMBED_URL=

# --- Flowise (RAG-Chatflows für Wissensbereiche) ---
# Chatflow-ID für die KorKI-Hilfe-Chatbubble (optional, erst nach Einrichtung in Flowise eintragen)
FLOWISE_CHATFLOW_ID=

# --- Whisper (Transkription) ---
# Auf CPU empfiehlt sich ein kleineres Modell als auf GPU-Servern (large-v3 ist auf CPU sehr langsam)
WHISPER_MODEL=

# --- FreiKI App ---
APP_URL=
JWT_SECRET=
KB_INGEST_API_KEY=
BOT_API_KEY=
HILFE_KB_TABLE=

# --- Brand-Konfiguration (White-Label) ---
APP_NAME=
APP_COLOR=
APP_COLOR_HOVER=
APP_COLOR_ACTIVE=
APP_NAVY=
APP_LOGO=
APP_LOGO_SIDEBAR=
APP_TAGLINE=
APP_SW_VERSION=
APP_SUPPORT_EMAIL=
APP_DEMO_MODE=
APP_FOOTER_NOTE=

# --- Mattermost (Team-Chat, OIDC-Login + n8n-Bot) ---
MATTERMOST_URL=
MATTERMOST_OIDC_CLIENT_ID=
MATTERMOST_OIDC_CLIENT_SECRET=
MATTERMOST_OIDC_REDIRECT_URI=
# Personal Access Token (n8n Bot-Posts)
MATTERMOST_BOT_TOKEN=

# --- Paperless-ngx (Dokumentenarchiv, Quelle für Wissensbereiche) ---
PAPERLESS_URL=
PAPERLESS_ADMIN_URL=
PAPERLESS_INTERNAL_URL=
PAPERLESS_SECRET_KEY=
PAPERLESS_ADMIN_USER=
PAPERLESS_ADMIN_PASSWORD=
PAPERLESS_TOKEN=

# --- Mailserver (eigener SMTP + IMAP, docker-mailserver) ---
MAIL_DOMAIN=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
