# chat.freiki.com - Mattermost Team-Chat (WebSocket wird von Caddy automatisch durchgereicht)
# Mattermost setzt eigene Header – nur HSTS ergänzen.
chat.freiki.com {
    header Strict-Transport-Security "max-age=31536000; includeSubDomains"
    header -Server
    reverse_proxy mattermost:8065 {
        flush_interval -1
        transport http {
            versions 1.1
        }
    }
    log {
        output file /var/log/caddy/chat-access.log
        format json
    }
}

# mail.freiki.com - Nur für TLS-Zertifikat; SMTP/IMAP laufen direkt über den Mailserver-Container
mail.freiki.com {
    respond "Mail server" 200
}
