# Caddy holt automatisch ein Let's-Encrypt-Zertifikat für die angegebenen Domains
# (DNS-A-Records müssen vorher auf den Server zeigen, sonst schlägt die Zertifikatsausstellung fehl).

# freiki.com - schlanke statische Landingpage (von Caddy selbst ausgeliefert, kein eigener Container nötig)
freiki.com {
    root * /srv/landing
    file_server
}

# app.freiki.com - die eigentliche FreiKI-App
app.freiki.com {
    reverse_proxy freiki-ui:3000
}

# n8n - NUR Webhooks öffentlich, Editor bleibt privat
# WICHTIG: braucht einen expliziten "route"-Block – ohne ihn sortiert Caddy
# "respond" automatisch VOR "reverse_proxy" (eigene Direktiven-Reihenfolge,
# unabhängig von der Schreibreihenfolge im File) und blockt dann ALLES,
# auch /webhook/*. Mit "route" bleibt die geschriebene Reihenfolge verbindlich.
n8n.freiki.com {
    route {
        @webhooks path /webhook/* /webhook-test/*
        reverse_proxy @webhooks n8n:5678
        respond "Access denied" 403
    }
}

# paperless.freiki.com - Dokumentenarchiv (Login über Paperless selbst geschützt)
paperless.freiki.com {
    reverse_proxy paperless:8000
}

# chat.freiki.com - Mattermost Team-Chat (WebSocket wird von Caddy automatisch durchgereicht)
chat.freiki.com {
    reverse_proxy mattermost:8065
}

# mail.freiki.com - Nur für TLS-Zertifikat; SMTP/IMAP laufen direkt über den Mailserver-Container
mail.freiki.com {
    respond "Mail server" 200
}
