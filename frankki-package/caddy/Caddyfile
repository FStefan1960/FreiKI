#         format json
#     }
# }

# chat.fst60.de - Mattermost Team-Chat
chat.fst60.de {
    header Strict-Transport-Security "max-age=31536000; includeSubDomains"
    header -Server
    reverse_proxy mattermost:8065 {
        flush_interval -1
        transport http {
            versions 1.1
        }
    }
    log {
        output file /var/log/caddy/chat-access.log
        format json
    }
}

# mail.fst60.de - Nur für TLS-Zertifikat; SMTP/IMAP laufen direkt über den Mailserver-Container
mail.fst60.de {
    respond "Mail server" 200
}
