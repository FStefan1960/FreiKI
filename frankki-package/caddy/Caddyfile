# Caddy holt automatisch ein Let's-Encrypt-Zertifikat für alle angegebenen Domains.
# DNS-A-Records müssen vorher auf fst60.de zeigen, sonst schlägt die Zertifikatsausstellung fehl.
# Benötigte A-Records:
#   fst60.de        → Server-IP
#   app.fst60.de    → Server-IP
#   n8n.fst60.de    → Server-IP
#   chat.fst60.de   → Server-IP
#   mail.fst60.de   → Server-IP
#   paperless.fst60.de → Server-IP (nur intern / Tailscale)

(security_headers) {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
        -Server
    }
}

# fst60.de - Landingpage (statisch, von Caddy ausgeliefert)
fst60.de {
    import security_headers
    header Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline' cdn.jsdelivr.net; font-src cdn.jsdelivr.net; img-src 'self' data:; script-src 'none'; base-uri 'self'; object-src 'none'"
    root * /srv/landing
    file_server
}

# app.fst60.de - Frank-KI App
app.fst60.de {
    import security_headers
    reverse_proxy frankki-ui:3000
    log {
        output file /var/log/caddy/app-access.log
        format json
    }
}

# paperless.fst60.de – nur intern via Tailscale, nicht öffentlich
# paperless.fst60.de {
#     header Strict-Transport-Security "max-age=31536000; includeSubDomains"
#     header Referrer-Policy "strict-origin-when-cross-origin"
#     header -Server
#     reverse_proxy paperless:8000
#     log {
