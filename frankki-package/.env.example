# ── Kopieren nach .env und alle Werte ausfüllen ──────────────────────────
# Niemals echte Werte hier eintragen oder ins Git committen.

# --- PostgreSQL ---
POSTGRES_USER=frankki_user
POSTGRES_PASSWORD=BITTE_AENDERN_starkes_passwort
POSTGRES_DB=frankki

# --- n8n ---
N8N_HOST=n8n.fst60.de
WEBHOOK_URL=https://n8n.fst60.de/
N8N_ENCRYPTION_KEY=BITTE_AENDERN_zufaelliger_string
N8N_WEBHOOK_URL=
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false

# --- LLM-Backend: Mistral API (OpenAI-kompatibel, europäischer Anbieter) ---
# API-Key unter https://console.mistral.ai/api-keys erzeugen
# Empfohlene Modelle: mistral-large-latest (stärkste), mistral-small-latest (günstig)
VLLM_URL=https://api.mistral.ai/v1
VLLM_API_KEY=BITTE_AENDERN_mistral_api_key
# Mistral Embedding-Modell (OpenAI-kompatibel)
VLLM_EMBED_URL=https://api.mistral.ai/v1/embeddings

# --- Whisper (Transkription, CPU) ---
# Optionen: tiny, base, small, medium, large-v3 (auf CPU: small empfohlen)
WHISPER_MODEL=small

# --- Frank-KI App ---
APP_URL=https://app.fst60.de
APP_NAME=Frank-KI
APP_TAGLINE=Dein persönlicher KI-Assistent
APP_FOOTER_NOTE=F. Stefan · 2026
APP_DEMO_MODE=false
APP_SW_VERSION=1
# Branding-Farben (CSS-Hex-Werte)
APP_COLOR=#1a6eb5
APP_COLOR_HOVER=#155a96
APP_COLOR_ACTIVE=#0f4575
APP_NAVY=#0d2d4a
# Logo-Dateipfade relativ zu /app/public (Datei muss in frankki-ui/public/ liegen)
APP_LOGO=logo.png
APP_LOGO_SIDEBAR=logo-sidebar.png

KORKI_JWT_SECRET=BITTE_AENDERN_zufaelliger_string_min_32_zeichen
KB_INGEST_API_KEY=BITTE_AENDERN_zufaelliger_string
BOT_API_KEY=BITTE_AENDERN_zufaelliger_string

# OpenID Connect: Frank-KI als Login-Provider für Mattermost
MATTERMOST_OIDC_CLIENT_ID=BITTE_AENDERN_zufaelliger_string
MATTERMOST_OIDC_CLIENT_SECRET=BITTE_AENDERN_zufaelliger_string
MATTERMOST_OIDC_REDIRECT_URI=https://chat.fst60.de/signup/gitlab/complete

# --- Paperless-ngx ---
PAPERLESS_URL=https://paperless.fst60.de
PAPERLESS_INTERNAL_URL=http://paperless:8000
PAPERLESS_TOKEN=BITTE_AENDERN_paperless_api_token
PAPERLESS_SECRET_KEY=BITTE_AENDERN_zufaelliger_string_min_50_zeichen
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=BITTE_AENDERN_starkes_passwort

# --- Mailserver (docker-mailserver, eigener SMTP + IMAP) ---
MAIL_DOMAIN=fst60.de
# SMTP_HOST zeigt auf den eigenen Mailserver-Container
SMTP_HOST=Mailserver
SMTP_PORT=587
SMTP_USER=noreply@fst60.de
SMTP_PASS=BITTE_AENDERN_starkes_passwort
SMTP_FROM=noreply@fst60.de

# --- Mattermost ---
MATTERMOST_URL=https://chat.fst60.de

# --- Flowise (RAG, optional – nur bei Wissensbereichen nötig) ---
FLOWISE_CHATFLOW_ID=
HILFE_KB_TABLE=kb_hilfe
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=BITTE_AENDERN_starkes_passwort
